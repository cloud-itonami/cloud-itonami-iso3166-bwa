#:culture{:id "bwa.dish.seswaa", :name "Seswaa", :country "BWA", :kind :dish, :summary "Traditional stewed meat dish of Botswana made from beef or goat, normally prepared for ceremonies such as funerals, weddings and independence celebrations.", :url "https://en.wikipedia.org/wiki/Seswaa", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.dish.bogobe-jwa-lerotse", :name "Bogobe jwa lerotse", :country "BWA", :kind :dish, :summary "Traditional porridge of sorghum meal and lerotse melon, described as a national dish of Botswana; the lerotse melon is indigenous to the country.", :url "https://en.wikipedia.org/wiki/Bogobe_jwa_lerotse", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.dish.dikgobe", :name "Dikgobe", :country "BWA", :kind :dish, :summary "Dish of samp and beans cooked together, with its place of origin given as Botswana, South Africa and Lesotho; a customary starch at Setswana celebrations such as marriages and funerals.", :url "https://en.wikipedia.org/wiki/Dikgobe", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.dish.morogo", :name "Morogo", :country "BWA", :kind :dish, :summary "Dark green leafy vegetables (African spinach) found throughout Southern Africa, including Botswana, forming an important part of the staple diet in rural communities.", :url "https://en.wikipedia.org/wiki/Morogo", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.product.mopane-worm", :name "Mopane worm", :country "BWA", :kind :product, :summary "Edible caterpillar of the emperor moth Gonimbrasia belina, an established food and important protein source in southern Africa; Botswana is a principal producer, earning roughly $8 million annually.", :url "https://en.wikipedia.org/wiki/Mopane_worm", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.beverage.chibuku-shake-shake", :name "Chibuku Shake Shake", :country "BWA", :kind :beverage, :summary "Commercial sorghum beer based on traditional African umqombothi beers; in Botswana it is brewed by Botswana Breweries, a subsidiary of Kgalagadi Breweries Limited.", :url "https://en.wikipedia.org/wiki/Chibuku_Shake_Shake", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.festival.dithubaruba", :name "Dithubaruba Cultural Festival", :country "BWA", :kind :festival, :summary "Annual national cultural festival held near Molepolole since 2007, celebrating the heritage of the Bakwena people and marked in the Botswana Calendar of Events.", :url "https://en.wikipedia.org/wiki/Dithubaruba_Cultural_Festival", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.heritage.tsodilo", :name "Tsodilo", :country "BWA", :kind :heritage, :summary "Hills in Ngamiland District, Botswana, with over 4,500 rock paintings; inscribed as a UNESCO World Heritage Site in 2001 for their religious and spiritual significance and record of human settlement.", :url "https://en.wikipedia.org/wiki/Tsodilo", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
#:culture{:id "bwa.heritage.okavango-delta", :name "Okavango Delta", :country "BWA", :kind :heritage, :summary "Vast inland delta in Botswana formed by the Okavango River, inscribed on 22 June 2014 as the 1000th UNESCO World Heritage Site.", :url "https://en.wikipedia.org/wiki/Okavango_Delta", :url-provenance :wikipedia-en, :retrieved-at "2026-07-17"}
